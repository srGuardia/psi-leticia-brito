---
import { env } from '@/types/env';
import { Mail, MapPin, Phone } from '@lucide/astro';
import { Icon } from 'astro-icon/components';

const currentYear = new Date().getFullYear();
---

<footer
  class="px-6 py-16 text-black bg-white"
  id="contact"
  data-section-theme="light"
>
  <div class="container mx-auto grid grid-cols-1 gap-12 md:grid-cols-3">
    <div class="space-y-6">
      <h3 class="font-extrabold text-2xl tracking-wider">
        Psicóloga&nbsp;<span class="font-extrabold text-brand"
          >Leticia Brito</span
        >
      </h3>

      <p class="max-w-xs font-light leading-relaxed">
        Psicoterapia Psicanalítica para crianças, adolescentes e adultos.
      </p>

      <p class="max-w-xs font-light leading-relaxed">
        Atendimento presencial e online, no Brasil e para brasileiros no
        exterior.
      </p>

      <p class="max-w-xs font-light leading-relaxed">
        Um espaço de escuta e transformação emocional.
      </p>

      <div class="flex gap-4">
        <a
          href={env.PUBLIC_INSTAGRAM_URL}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Link para o instagram"
          class="rounded-full p-2 transition-colors hover:bg-brand active:bg-brand"
        >
          <Icon name="instagram" size={20} />
        </a>
        <a
          href={env.PUBLIC_FACEBOOK_URL}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Link para o facebook"
          class="rounded-full p-2 transition-colors hover:bg-brand active:bg-brand"
        >
          <Icon name="facebook" size={20} />
        </a>
      </div>
    </div>

    <div class="space-y-6">
      <h4 class="font-bold text-lg">Localização</h4>
      <div class="space-y-4">
        <div
          class="flex items-start gap-3 transition-colors hover:text-gray-600"
        >
          <MapPin size={20} class="mt-1 shrink-0 text-brand" />
          <address class="font-light not-italic">{env.PUBLIC_ADDRESS}</address>
        </div>
      </div>
    </div>

    <div class="space-y-6">
      <h4 class="font-bold text-lg">Contato</h4>
      <div class="space-y-4">
        <a
          href={`https://wa.me/${env.PUBLIC_WHATSAPP_NUMBER}?text=Olá%2C%20eu%20vim%20pelo%20site`}
          class="flex items-center gap-3 transition-colors hover:text-gray-600"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Link para o whatsapp"
        >
          <Phone size={20} class="text-brand" />
          <p class="font-light">WhatsApp Business</p>
        </a>
        <div class="flex items-center gap-3">
          <Mail size={20} class="text-brand" />
          <a
            href={`mailto:${env.PUBLIC_EMAIL}`}
            class="flex items-center gap-3 transition-colors hover:text-gray-600"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Link para o e-mail"
          >
            {env.PUBLIC_EMAIL}
          </a>
        </div>
      </div>
    </div>
  </div>

  <div
    class="container mx-auto mt-16 flex flex-col items-center justify-between gap-4 border-white/10 border-t pt-8 font-light text-sm md:flex-row"
  >
    <p class="font-medium">
      © {currentYear} Psicóloga Leticia Brito. Todos os direitos reservados.
    </p>
    <p class="font-medium">CRP 12/30305</p>
  </div>
</footer>
