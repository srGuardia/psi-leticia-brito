---
import SectionContent from './section.astro';

const services = [
  {
    icon: '🧠',
    title: 'Terapia Individual',
    description: 'Acompanhamento personalizado para suas necessidades.',
  },
  {
    icon: '💼',
    title: 'Orientação profissional',
    description: 'Escolhas claras e direcionadas, para o seu sucesso.',
  },
  {
    icon: '🌿',
    title: 'Apoio à Ansiedade',
    description: 'Estratégias para manejo da ansiedade e do estresse.',
  },
  {
    icon: '✨',
    title: 'Autoconhecimento',
    description: 'Exploração de padrões e construção de novos caminhos.',
  },
  {
    icon: '🌈',
    title: 'Psicoterapia Infantil',
    description:
      'Espaço seguro para a criança expressar emoções, desenvolver autonomia e fortalecer vínculos.',
  },
  {
    icon: '🌍',
    title: 'Brasileiros no exterior',
    description:
      'Acolhimento psicológico para quem vive fora do país e enfrenta desafios de adaptação, identidade e pertencimento.',
  },
  {
    icon: '🔎',
    title: 'Recrutamento e seleção de pessoas',
    description: 'Avaliação psicológica para seleção de candidatos.',
  },
  {
    icon: '📝',
    title: 'Implementação da NR-1',
    description:
      'Gestão de riscos psicossociais e estratégias para fortalecer a saúde mental no ambiente corporativo.',
  },
];
---

<SectionContent theme="light" class="bg-[#FAF7FB] pt-5" id="services">
  <div class="container mx-auto max-w-7xl px-4">
    <h2
      class="mb-20 text-center font-serif text-4xl text-[#2e2143] italic md:text-5xl lg:text-6xl"
    >
      Como posso te ajudar
    </h2>

    <div class="flex flex-wrap justify-center gap-6 overflow-hidden lg:gap-8">
      {
        services.map((service, index) => (
          <div class="group flex w-full flex-col items-start rounded-[2.5rem] border border-white/60 bg-white p-6 shadow-[0_4px_20px_rgba(0,0,0,0.02)] transition-all duration-500 hover:-translate-y-2 hover:shadow-[0_30px_60px_rgba(0,0,0,0.08)] sm:w-[calc(50%-12px)] md:p-10 lg:w-[calc(33.33%-22px)] xl:w-[calc(25%-24px)]">
            <div class="mb-8 flex h-16 w-16 items-center justify-center rounded-2xl bg-[#FAF7FB] text-4xl transition-transform duration-500 group-hover:rotate-3 group-hover:scale-110">
              {service.icon}
            </div>
            <h3 class="mb-4 font-bold text-[#2e2143] text-xl tracking-tight">
              {service.title}
            </h3>
            <p class="font-light text-[0.95rem] text-slate-500 leading-relaxed">
              {service.description}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</SectionContent>
